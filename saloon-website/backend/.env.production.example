# Production backend (Render / Railway / VPS). Never commit real secrets.

NODE_ENV=production
PORT=5000

# PostgreSQL (Neon / Supabase / RDS / Render Postgres)
DB_HOST=your-db-host.region.provider.com
DB_PORT=5432
DB_NAME=salon_db
DB_USER=salon_user
DB_PASSWORD=use_a_long_random_password
DB_SSL=true

# JWT — use a long random string (32+ bytes); rotate if leaked
JWT_SECRET=replace_with_openssl_rand_hex_64
JWT_EXPIRE=7d

# Uploads — use persistent disk path on host (see host docs) or later S3
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# CORS: exact origins of your deployed frontend(s), comma-separated, no trailing slashes
# Include www and non-www if both exist
FRONTEND_URL=https://app.yourdomain.com,https://www.yourdomain.com

# Used by some features (e.g. QR links) — first URL wins if comma list
# FRONTEND_URL is also read split by comma in qr.controller

# Abuse protection (adjust after observing traffic)
RATE_LIMIT_MAX=400
AUTH_RATE_LIMIT_MAX=20
