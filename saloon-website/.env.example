# Copy to .env.local for local dev, or set in Vercel/Netlify → Environment Variables
# Vite only exposes variables prefixed with VITE_

# Production: your API base URL (must include /api path used by the app)
# Example: https://api.yourdomain.com/api
VITE_API_URL=https://your-backend-host.example.com/api

# Optional: default public salon slug when no ?salon= and no localStorage (multi-tenant)
# VITE_DEFAULT_SALON_SLUG=minjal-cuttack
